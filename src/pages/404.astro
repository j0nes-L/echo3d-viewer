---
import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SnapSpace · 404 Not Found</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
</head>
<body class="privacy-page">

<div class="privacy-container" style="align-items:center; justify-content:center; text-align:center;">
    <div style="padding: 48px 24px; display:flex; flex-direction:column; align-items:center; gap:24px;">
        <div style="font-family:'Fredoka',sans-serif; font-size:96px; font-weight:600; color:var(--border-color); line-height:1;">
            404
        </div>
        <div style="display:flex; flex-direction:column; gap:8px;">
            <h1 style="font-size:20px; font-weight:600; color:var(--text-primary);">Page not found</h1>
            <p style="font-size:14px; color:var(--text-secondary); max-width:360px;">
                The page you're looking for doesn't exist or has been moved.
            </p>
        </div>
        <div style="display:flex; gap:10px; flex-wrap:wrap; justify-content:center;">
            <a href="/" class="btn btn-accent" style="height:36px; padding:0 20px; font-size:13px; text-decoration:none;">
                ← Back to Viewer
            </a>
            <a href="/account" class="btn btn-secondary" style="height:36px; padding:0 20px; font-size:13px; text-decoration:none;">
                Account
            </a>
        </div>
    </div>

    <footer class="app-footer">
        <span>&copy; Jonas Ludorf</span>
        <span class="footer-sep">|</span>
        <a href="/privacy" class="footer-link">Privacy Policy</a>
        <span class="footer-sep">|</span>
        <a href="https://jonasludorf.dev/legal/" class="footer-link">Legal Note</a>
    </footer>
</div>

</body>
</html>

