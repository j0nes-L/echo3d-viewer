---
import '../styles/global.css';
import {createSupabaseServerClient} from '../lib/supabase-server';

const supabase = createSupabaseServerClient(
    Astro.cookies,
    Astro.request.headers.get('Cookie') ?? ''
);
const {data: {user}} = await supabase.auth.getUser();

let displayName: string | null = null;
if (user) {
    const {data} = await supabase
        .from('profiles')
        .select('display_name')
        .eq('id', user.id)
        .single();
    // Fallback: read from auth metadata if profiles row has no display_name yet
    displayName = data?.display_name
        ?? (user.user_metadata?.display_name as string | undefined)
        ?? null;
}
---
<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SnapSpace · Point Cloud Viewer</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
</head>
<body>

<div class="admin-fixed">
    <a href="/account" class={`btn ${user ? 'btn-account-user' : 'btn-account-login'}`} title="Account" aria-label="Account">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="8" r="4"/>
            <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
        </svg>
        {user ? (displayName ?? user.email ?? 'Account') : 'LOGIN'}
    </a>
</div>

<div id="app-screen" class="app-layout">
    <div class="main-area">
        <aside id="sidebar" class="sidebar">
            <div class="sidebar-topbar">
                <div class="topbar-brand">
                    <span class="logo">[SnapSpace]</span>
                    <span class="topbar-subtitle">Point Cloud Viewer</span>
                </div>
                <button id="refresh-btn" class="btn btn-icon" title="Refresh">&#8635;</button>
            </div>
            <div class="sidebar-body">
                <div class="sidebar-section-label">Captures</div>
                <div id="session-list">
                    <div class="empty-state">No captures available.</div>
                </div>
            </div>
        </aside>
        <button id="sidebar-toggle" class="sidebar-edge-toggle" title="Toggle sidebar">&#8249;</button>
        <div id="viewer" class="viewer-container">
            <div id="point-size-control" class="point-size-control hidden">
                <label for="point-size-slider">Size</label>
                <input id="point-size-slider" type="range" min="0.001" max="0.05" step="0.001" value="0.005"/>
            </div>
            <div class="viewer-empty">Select a point cloud to view</div>
            <div id="viewer-loading" class="viewer-loading hidden">
                <div class="spinner-large"></div>
                <div id="viewer-progress" class="viewer-progress">0 %</div>
            </div>
            <div id="status" class="viewer-status"></div>
        </div>
    </div>
    <footer class="app-footer">
        <span>&copy; Jonas Ludorf</span>
        <span class="footer-sep">|</span>
        <a href="/privacy" class="footer-link">Privacy Policy</a>
        <span class="footer-sep">|</span>
        <a href="https://jonasludorf.dev/legal/" class="footer-link">Legal Note</a>
    </footer>
</div>

<div id="item-downloads-section" class="item-downloads-section">
    <div class="item-downloads-inner">
        <div class="dl-slot" id="dl-slot-ply">
            <div class="dl-slot-inner">
                <button id="download-btn" class="btn btn-download">⤓ .ply</button>
            </div>
        </div>
        <div class="dl-slot" id="dl-slot-colmap">
            <div class="dl-slot-inner">
                <button id="download-colmap-btn" class="btn btn-download">⤓ COLMAP</button>
            </div>
        </div>
        <div class="dl-slot" id="dl-slot-mesh">
            <div class="dl-slot-inner">
                <button id="download-mesh-btn" class="btn btn-download">⤓ .glb</button>
            </div>
        </div>
        <div class="dl-slot" id="dl-slot-delete">
            <div class="dl-slot-inner" style="padding-top:4px">
                <button id="item-delete-btn" class="btn btn-download btn-download-danger">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:6px;flex-shrink:0"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                    Delete Capture
                </button>
            </div>
        </div>
    </div>
</div>

<script src="../scripts/toast.ts"></script>
<script src="../scripts/app.ts"></script>
</body>
</html>

