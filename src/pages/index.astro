---
import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SnapSpace · Point Cloud Viewer</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
</head>
<body>

<!-- Admin Login Modal -->
<div id="admin-modal" class="modal-overlay hidden">
    <div class="modal-card">
        <div class="modal-header">
            <span class="modal-title">Admin Login</span>
            <button id="modal-close-btn" class="btn btn-icon" title="Close">&#x2715;</button>
        </div>
        <form id="admin-login-form" autocomplete="on">
            <label class="login-label" for="admin-password">Password</label>
            <input
                    id="admin-password"
                    type="password"
                    class="login-input"
                    placeholder="Enter admin password…"
                    autocomplete="current-password"
                    required
            />
            <div id="admin-login-error" class="login-error hidden"></div>
            <div class="modal-actions">
                <button type="submit" id="admin-login-btn" class="btn btn-accent login-btn">Login</button>
            </div>
        </form>
    </div>
</div>

<div id="app-screen" class="app-layout">
    <header class="topbar">
        <div class="topbar-brand">
            <span class="logo">[SnapSpace]</span>
            <span class="subtitle">Point Cloud Viewer</span>
        </div>
        <div id="status" class="topbar-status"></div>
        <div class="topbar-right">
            <button id="admin-btn" class="btn btn-secondary" title="Admin Login">Admin</button>
            <button id="logout-btn" class="btn btn-icon hidden" title="Logout">&#x23FB;</button>
        </div>
    </header>
    <div class="main-area">
        <button id="sidebar-toggle" class="btn btn-icon sidebar-toggle-float" title="Toggle sidebar">&#9776;</button>
        <aside id="sidebar" class="sidebar">
            <div class="sidebar-header">
                <div style="display:flex;align-items:center;gap:8px;">
                    <h2>Point Clouds</h2>
                </div>
                <div class="sidebar-actions">
                    <button id="refresh-btn" class="btn btn-icon" title="Refresh">&#8635;</button>
                </div>
            </div>
            <div class="sidebar-body">
                <div id="session-list">
                    <div class="empty-state">No captures available.</div>
                </div>
            </div>
        </aside>
        <div id="viewer" class="viewer-container">
            <div id="point-size-control" class="point-size-control hidden">
                <button id="download-btn" class="btn btn-download hidden" title="Download .ply">⤓ .ply</button>
                <button id="download-colmap-btn" class="btn btn-download hidden" title="Download COLMAP .zip">⤓ COLMAP
                </button>
                <button id="download-mesh-btn" class="btn btn-download hidden"
                        title="Download Mesh .glb (Experimental)">⤓ .glb
                </button>
                <label for="point-size-slider">Size</label>
                <input id="point-size-slider" type="range" min="0.001" max="0.05" step="0.001" value="0.005"/>
            </div>
            <div class="viewer-empty">Select a point cloud to view</div>
            <div id="viewer-loading" class="viewer-loading hidden">
                <div class="spinner-large"></div>
                <div id="viewer-progress" class="viewer-progress">0 %</div>
            </div>
        </div>
    </div>
    <footer class="app-footer">
        <span>&copy; Jonas Ludorf</span>
        <span class="footer-sep">|</span>
        <a href="/privacy" class="footer-link">Privacy Policy</a>
    </footer>
</div>

<script src="../scripts/app.ts"></script>
</body>
</html>

